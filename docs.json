{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "Grounded Systems",
  "description": "Modernize from within, with a small senior team that helps yours make real progress without giving up ownership.",
  "colors": {
    "primary": "#1e40af"
  },
  "logo": "/images/og-image.png",
  "favicon": "/images/og-image.png",
  "appearance": {
    "default": "light",
    "strict": true
  },
  "fonts": {
    "heading": {
      "family": "Fraunces"
    },
    "body": {
      "family": "Source Sans 3"
    }
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "search": {
    "prompt": "Search documentation...",
    "location": "top"
  },
  "seo": {
    "metatags": {
      "viewport": "width=device-width, initial-scale=1.0"
    }
  },
  "navigation": {
    "$ref": "./config/navigation.json"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Start a Conversation",
      "href": "https://github.com/lagebj/docs/issues/new"
    },
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/lagebj/docs"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/lagebj/docs"
    }
  }
}
