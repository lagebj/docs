{
  "name": "grounded-systems",
  "private": true,
  "scripts": {
    "dev": "mintlify dev",
    "build:css": "npx tailwindcss -i ./src/styles/components.css -o ./output.css --minify",
    "watch:css": "npx tailwindcss -i ./src/styles/components.css -o ./output.css --watch",
    "links": "mintlify broken-links",
    "lint:md": "markdownlint \"**/*.{md,mdx}\" --ignore node_modules",
    "format:check": "pre-commit run --all-files",
    "verify": "npm run links && npm run lint:md && npm run format:check",
    "test:components": "open src/test/components-test.html",
    "size:css": "npx gzip-size output.css --include-original"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "markdownlint-cli": "^0.48.0",
    "mintlify": "^4.0.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.3"
  },
  "version": "0.5.0",
  "description": "This repository contains the Mintlify documentation site for **Grounded Systems**.",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lagebj/docs.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/lagebj/docs/issues"
  },
  "homepage": "https://github.com/lagebj/docs#readme",
  "dependencies": {
    "fuse.js": "^7.3.0"
  }
}
