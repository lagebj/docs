{
  "name": "grounded-systems",
  "private": true,
  "scripts": {
    "dev": "mintlify dev",
    "build:css": "postcss style.css -o output.css",
    "build:css-sections": "postcss css/sections/*.css -d css/sections/output/",
    "build:all-css": "npm run build:css && npm run build:css-sections",
    "build:test": "postcss test.css -o test-output.css",
    "links": "mintlify broken-links",
    "lint:md": "markdownlint \"**/*.{md,mdx}\" --ignore node_modules",
    "format:check": "pre-commit run --all-files",
    "setup:agent": "bash scripts/agents/setup-opencode-adapter.sh",
    "verify": "npm run links && npm run lint:md && npm run format:check"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "autoprefixer": "^10.5.0",
    "cssnano": "^7.1.7",
    "markdownlint-cli": "^0.48.0",
    "mintlify": "^4.0.0",
    "postcss": "^8.5.10",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^4.2.3"
  },
  "version": "0.5.0",
  "description": "This repository contains the Mintlify documentation site for **Grounded Systems**.",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lagebj/docs.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/lagebj/docs/issues"
  },
  "homepage": "https://github.com/lagebj/docs#readme",
  "dependencies": {
    "fuse.js": "^7.3.0",
    "web-vitals": "^5.2.0"
  }
}
